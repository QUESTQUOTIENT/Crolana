# ============================================
# CROLANA ANDROID BUILD CONFIGURATION
# ============================================
#
# Copy this file to .env and fill in values before building.
#
# QUICK START:
# 1.cp .env.example .env
# 2. Edit .env with your production values
# 3. npm run build
# 4. npx cap sync android
# 5. npx cap open android && Build Signed APK

# --------------------------------------------
# WALLETCONNECT (Required for mobile wallet connections)
# --------------------------------------------
# Get your Project ID from: https://cloud.walletconnect.com
# Sign up → Create Project → Copy Project ID
VITE_ENABLE_WALLETCONNECT=true
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE

# --------------------------------------------
# BACKEND URL (Required for production)
# --------------------------------------------
# The Android app will connect to this backend API.
# Deploy the Express server first (see README.md / railway.json).
# Examples:
# - Railway: https://crolana-production.up.railway.app
# - Render: https://crolana.onrender.com
# - Custom VPS: https://api.yourdomain.com
CAPACITOR_URL=https://your-backend-url.com

# --------------------------------------------
# OPTIONAL: External API Keys (set on backend instead!)
# --------------------------------------------
# These should be set on the backend server's environment,
# NOT in the Android app. The app only talks to your backend.
# Listed here for reference only:
# HELIUS_API_KEY=
# COVALENT_API_KEY=
# LIGHTHOUSE_API_KEY=
# PINATA_API_KEY=
# PINATA_SECRET=

# --------------------------------------------
# METADATA RESOLVER SIDE CAR (new)
# --------------------------------------------
# URL of the metadata-resolver microservice. Defaults to localhost:3001.
# Set this if the metadata service runs on a different host/port.
# METADATA_SERVICE_URL=http://localhost:3001

# --------------------------------------------
# BUILD FLAGS
# --------------------------------------------
NODE_ENV=production
