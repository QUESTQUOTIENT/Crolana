# ─────────────────────────────────────────────────────────────────────────────
# Crolana v7 — Environment Configuration  (Fix #9: Chain-Split ENV)
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_char_encryption_key_here_change_me
JWT_SECRET=your_jwt_secret_here_change_me_minimum_32_chars

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
DATABASE_URL=postgresql://studio:studio_pass@localhost:5432/cronos_studio?schema=public

# ── Redis (session cache, rate limiting) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════
# ██████  CRONOS (EVM) CONFIG
# ═══════════════════════════════════════════════════════════════

# RPC Endpoints
CRONOS_MAINNET_RPC=https://evm.cronos.org
CRONOS_TESTNET_RPC=https://cronos-testnet.drpc.org

# WebSocket (for event listeners)
CRONOS_WS_MAINNET=wss://ws.cronos.org
CRONOS_WS_TESTNET=wss://cronos-testnet.drpc.org

# Active network for backend operations: "mainnet" | "testnet"
CRONOS_ACTIVE_NETWORK=mainnet

# Cronoscan (contract verification + analytics)
CRONOSCAN_API_KEY=

# Covalent API (NFT ownership sync for EVM)
COVALENT_API_KEY=

# Moralis API (alternative EVM indexer)
MORALIS_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ██████  SOLANA CONFIG
# ═══════════════════════════════════════════════════════════════

# RPC Endpoints
# Get a free endpoint at https://helius.dev (recommended) or https://rpc.ankr.com
SOLANA_MAINNET_RPC=https://rpc.ankr.com/solana
SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Active cluster: "mainnet" | "devnet"
SOLANA_ACTIVE_CLUSTER=mainnet

# Helius API Key — required for NFT ownership sync + DAS API (getAssetsByOwner)
# Free tier: 100K credits/day. Get at https://helius.dev
HELIUS_API_KEY=

# Helius webhook secret (for event push to /api/webhooks/helius)
HELIUS_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════
# ██████  SHARED / IPFS CONFIG
# ═══════════════════════════════════════════════════════════════

# IPFS Providers (configure ONE of the following)

# Option 1 — Pinata (recommended)
PINATA_API_KEY=
PINATA_SECRET=
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Option 2 — Infura
INFURA_PROJECT_ID=
INFURA_PROJECT_SECRET=

# Option 3 — Lighthouse
LIGHTHOUSE_API_KEY=

# ── Event Listener / Indexer ──────────────────────────────────────────────────
# Comma-separated Cronos contract addresses to watch on startup
WATCHED_CONTRACTS=
POLL_INTERVAL_MS=30000

# ── Marketplace ───────────────────────────────────────────────────────────────
# Tensor API key for Solana marketplace queries (optional)
TENSOR_API_KEY=

# Magic Eden API key (optional)
MAGIC_EDEN_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ██████  FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════

# WalletConnect v3 (Reown AppKit) — set to true to enable WalletConnect QR/deeplink
# Requires a free projectId from https://cloud.reown.com
# When false (default): app uses injected wallets + deep links only (lighter, works great for most users)
VITE_ENABLE_WALLETCONNECT=false
VITE_WALLETCONNECT_PROJECT_ID=

# Multi-router DEX — when true: quotes from both VVS Finance and MM Finance, best route auto-selected
VITE_ENABLE_MULTI_ROUTER=false

# Sentry error monitoring
VITE_SENTRY_DSN=
SENTRY_DSN=
