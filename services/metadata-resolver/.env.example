# Metadata Resolver Service
# Separate sidecar for resolving NFT metadata from IPFS and external sources

NODE_ENV=development
PORT=3001

# Redis (optional - for distributed caching)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# External fetch timeout (ms)
FETCH_TIMEOUT=10000

# Allowed external domains (comma-separated,leave empty for all)
ALLOWED_EXTERNAL_DOMAINS=drive.google.com,dropbox.com,ipfs.io,cloudflare-ipfs.com
