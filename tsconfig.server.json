{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["server.ts", "server/**/*", "src/lib/**/*"],
  "exclude": ["node_modules", "dist", "src/components", "src/pages", "src/hooks", "src/engines", "src/services", "src/marketplace", "src/contracts", "src/data", "src/security", "packages"]
}
