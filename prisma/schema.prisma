// Cronos Studio v7.1 — Prisma Schema
// Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth & Identity
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets     Wallet[]
  collections Collection[]
  tokens      Token[]
  swaps       SwapTransaction[]
  positions   LiquidityPool[]
  sessions    Session[]
}

model Wallet {
  id          String      @id @default(cuid())
  address     String
  // EVM: numeric chain ID (25 = Cronos). Solana: 0
  chainId     Int         @default(25)
  // "cronos" | "solana"
  chain       ChainType   @default(CRONOS)
  walletType  String      @default("metamask")  // metamask | phantom | cryptocom | etc
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPrimary   Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@unique([address, chain])
  @@index([address])
  @@index([userId])
  @@index([chain])
}

enum ChainType {
  CRONOS
  SOLANA
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  nonce     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// ─────────────────────────────────────────────────────────────
// NFT Collections
// ─────────────────────────────────────────────────────────────

model Collection {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  name        String
  symbol      String
  description String?          @db.Text
  bannerUrl   String?
  externalUrl String?
  totalSupply Int              @default(0)
  maxSupply   Int
  mintPrice   String           @default("0")
  royaltyBps  Int              @default(500)
  royaltyAddr String?
  network     String           @default("mainnet")
  // ── Multi-chain fields (Fix #2) ──────────────────────────────
  // EVM: numeric chain ID (25 = Cronos mainnet, 338 = testnet). Solana: 0
  chainId     Int              @default(25)
  // "cronos" | "solana"
  chain       ChainType        @default(CRONOS)
  // Solana: collection mint pubkey. EVM: null
  mintAddress String?
  // EVM: deployed contract address. Solana: null
  contractAddress String?
  // ─────────────────────────────────────────────────────────────
  status      CollectionStatus @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  nfts        NFT[]
  contract    Contract?
  mintPhases  MintPhase[]
  walletMints WalletMint[]
  whitelist   WhitelistEntry[]
  analytics   AnalyticsSnapshot[]

  @@index([userId])
  @@index([status])
  @@index([chain])
  @@index([contractAddress])
  @@index([mintAddress])
}

enum CollectionStatus {
  DRAFT
  READY
  LIVE
  SOLD_OUT
  PAUSED
}

model NFT {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  // ── Chain-specific identifiers (Fix #2) ─────────────────────
  // EVM: sequential integer token ID
  tokenId      Int?
  // Solana: base58 mint address (32 bytes)
  mintAddress  String?
  // "cronos" | "solana" — denormalised from Collection for fast queries
  chain        ChainType  @default(CRONOS)
  // ─────────────────────────────────────────────────────────────

  name         String
  description  String?    @db.Text
  dnaHash      String
  rarity       Float      @default(0)
  rarityRank   Int?
  isLegendary  Boolean    @default(false)
  imageCid     String?
  metadataCid  String?
  ipfsUri      String?
  metadataUri  String?    // resolved URI (https or ipfs://)
  attributes   Json       @default("[]")

  // Ownership
  owner        String?    // wallet address (EVM or Solana pubkey)
  mintedAt     DateTime?
  mintedBy     String?
  createdAt    DateTime   @default(now())

  mintEvent MintEvent?

  @@unique([collectionId, dnaHash])
  @@index([collectionId])
  @@index([tokenId])
  @@index([mintAddress])
  @@index([chain])
  @@index([owner])
}

// ─────────────────────────────────────────────────────────────
// Contracts
// ─────────────────────────────────────────────────────────────

model Contract {
  id               String     @id @default(cuid())
  collectionId     String?    @unique
  collection       Collection? @relation(fields: [collectionId], references: [id])
  userId           String?
  address          String
  chainId          Int
  txHash           String?
  contractType     String     @default("ERC721")
  name             String
  symbol           String
  abi              Json?
  bytecode         String?    @db.Text
  sourceCode       String?    @db.Text
  compilerVersion  String?
  verified         Boolean    @default(false)
  deployedAt       DateTime   @default(now())

  mintEvents       MintEvent[]
  transferEvents   TransferEvent[]

  @@index([address, chainId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Minting
// ─────────────────────────────────────────────────────────────

model MintPhase {
  id             String     @id @default(cuid())
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name           String
  phaseType      PhaseType  @default(PUBLIC)
  startTime      DateTime
  endTime        DateTime?
  price          String     @default("0")   // In wei
  maxPerWallet   Int        @default(0)     // 0 = unlimited
  maxSupply      Int?                        // Phase cap (null = collection cap)
  merkleRoot     String?
  isActive       Boolean    @default(false)
  order          Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  walletMints WalletMint[]

  @@index([collectionId])
  @@index([isActive])
}

enum PhaseType {
  ALLOWLIST
  PUBLIC
  FCFS
  DUTCH_AUCTION
}

model WalletMint {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  phaseId      String?
  phase        MintPhase? @relation(fields: [phaseId], references: [id])
  walletAddress String
  quantity     Int        @default(1)
  txHash       String?
  mintedAt     DateTime   @default(now())

  @@index([collectionId, walletAddress])
  @@index([phaseId])
}

model WhitelistEntry {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  address      String
  maxMints     Int        @default(1)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, address])
  @@index([collectionId])
  @@index([address])
}

// ─────────────────────────────────────────────────────────────
// Blockchain Events
// ─────────────────────────────────────────────────────────────

model MintEvent {
  id              String   @id @default(cuid())
  contractId      String?
  contract        Contract? @relation(fields: [contractId], references: [id])
  nftId           String?  @unique
  nft             NFT?     @relation(fields: [nftId], references: [id])
  txHash          String
  blockNumber     Int
  tokenId         Int?
  minterAddress   String
  toAddress       String
  value           String   @default("0")  // In wei
  chainId         Int      @default(25)
  timestamp       DateTime @default(now())

  @@index([contractId])
  @@index([minterAddress])
  @@index([blockNumber])
}

model TransferEvent {
  id          String   @id @default(cuid())
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id])
  txHash      String
  blockNumber Int
  tokenId     Int?
  fromAddress String
  toAddress   String
  chainId     Int      @default(25)
  timestamp   DateTime @default(now())

  @@index([contractId])
  @@index([fromAddress])
  @@index([toAddress])
}

// ─────────────────────────────────────────────────────────────
// Tokens (ERC-20)
// ─────────────────────────────────────────────────────────────

model Token {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  address       String?
  chainId       Int      @default(25)
  txHash        String?
  name          String
  symbol        String
  decimals      Int      @default(18)
  initialSupply String
  maxSupply     String?
  isMintable    Boolean  @default(false)
  isBurnable    Boolean  @default(false)
  isPausable    Boolean  @default(false)
  hasTax        Boolean  @default(false)
  taxBps        Int      @default(0)
  isGovernance  Boolean  @default(false)
  sourceCode    String?  @db.Text
  abi           Json?
  verified      Boolean  @default(false)
  deployedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([address, chainId])
}

// ─────────────────────────────────────────────────────────────
// DeFi — Swaps & Liquidity
// ─────────────────────────────────────────────────────────────

model SwapTransaction {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  txHash       String
  chainId      Int      @default(25)
  tokenIn      String
  tokenOut     String
  amountIn     String
  amountOut    String
  dexName      String
  slippageBps  Int      @default(50)
  executedAt   DateTime @default(now())

  @@index([userId])
  @@index([txHash])
}

model LiquidityPool {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  pairAddress String
  tokenA      String
  tokenB      String
  chainId     Int      @default(25)
  dexName     String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([pairAddress, chainId])
}

// ─────────────────────────────────────────────────────────────
// Analytics
// ─────────────────────────────────────────────────────────────

model AnalyticsSnapshot {
  id              String     @id @default(cuid())
  collectionId    String
  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  date            String     // YYYY-MM-DD
  totalMinted     Int        @default(0)
  uniqueOwners    Int        @default(0)
  mintsCount      Int        @default(0)
  revenueWei      String     @default("0")
  mintVelocity    Float      @default(0)
  createdAt       DateTime   @default(now())

  @@unique([collectionId, date])
  @@index([collectionId])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// Metadata & IPFS
// ─────────────────────────────────────────────────────────────

model Metadata {
  id           String   @id @default(cuid())
  collectionId String?
  nftId        String?
  cid          String
  uri          String
  gatewayUrl   String?
  provider     String
  type         String   @default("metadata")  // images | metadata | hidden
  fileCount    Int      @default(1)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([cid])
  @@index([collectionId])
}

// ─────────────────────────────────────────────────────────────
// Marketplace Listings  (Fix #2, Fix #3)
// Tracks NFT listings across Cronos and Solana.
// ─────────────────────────────────────────────────────────────

model NFTListing {
  id              String        @id @default(cuid())
  chain           ChainType
  // EVM
  contractAddress String?
  tokenId         String?
  // Solana
  mintAddress     String?
  // Common
  seller          String
  price           String        // in native units (wei or lamports) as string
  priceFormatted  String        // human-readable e.g. "1.5 CRO"
  currency        String        @default("CRO") // "CRO" | "SOL"
  marketplace     String        @default("native")
  listingTxHash   String?
  saleTxHash      String?
  status          ListingStatus @default(ACTIVE)
  listedAt        DateTime      @default(now())
  expiresAt       DateTime?
  soldAt          DateTime?
  soldTo          String?

  @@index([chain, status])
  @@index([contractAddress, tokenId])
  @@index([mintAddress])
  @@index([seller])
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────
// Transaction Tracking  (Fix #7)
// Persists TX records for both chains.
// ─────────────────────────────────────────────────────────────

model TrackedTransaction {
  id             String    @id @default(cuid())
  chain          ChainType
  txHash         String
  walletAddress  String
  status         TxStatus  @default(PENDING)
  blockNumber    Int?
  slot           Int?       // Solana slot
  fee            String?
  errorMessage   String?
  metadata       Json?      // e.g. { type: 'mint', collectionId: '...' }
  confirmedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([txHash, chain])
  @@index([walletAddress, chain])
  @@index([status])
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Ownership Sync Cache  (Fix #11, #12)
// Stores the last known NFT ownership state per wallet.
// ─────────────────────────────────────────────────────────────

model OwnershipCache {
  id            String    @id @default(cuid())
  walletAddress String
  chain         ChainType
  nftCount      Int       @default(0)
  // JSON array of { id, chain, mintAddress?, contractAddress?, tokenId?, name, image, isListed }
  snapshot      Json      @default("[]")
  source        String    @default("helius")  // helius | covalent | moralis | rpc
  syncedAt      DateTime  @default(now())

  @@unique([walletAddress, chain])
  @@index([walletAddress])
  @@index([chain])
}
