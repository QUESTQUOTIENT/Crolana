{
  "name": "crolana",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Crolana — NFT + DeFi Launchpad for the Cronos blockchain",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite",
    "dev:listener": "tsx services/cronos-listener/index.ts",
    "dev:indexer": "tsx services/analytics-indexer/index.ts",
    "dev:metadata": "tsx services/metadata-resolver/index.ts",
    "build:packages": "npm run build --prefix packages/nft-engine && npm run build --prefix packages/liquidity-engine && npm run build --prefix packages/swap-engine && npm run build --prefix packages/token-engine",
    "build": "npm run build:packages && prisma generate && vite build",
    "build:icons": "node scripts/generate-icons.cjs && node scripts/generate-android-icons.cjs",
    "build:prod": "NODE_ENV=production npm run build",
    "preview": "vite preview",
    "start": "tsx server.ts",
    "start:listener": "NODE_ENV=production tsx services/cronos-listener/index.ts",
    "start:indexer": "NODE_ENV=production tssx services/analytics-indexer/index.ts",
    "start:metadata": "NODE_ENV=production tsx services/metadata-resolver/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "type-check:server": "tsc -p tsconfig.server.json --noEmit",
    "lint:fix": "tsc --noEmit && echo \"No type errors found\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "cap:init": "npx cap init Crolana com.crolana.app --web-dir=dist",
    "cap:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npm run build:prod && npx cap sync android && echo '\n✅ Web assets synced to Android project.\n\nNext: Run one of:\n  npx cap open android (Android Studio GUI)\n  cd android && ./gradlew assembleRelease (CLI)\n'",
    "cap:apk": "npm run build:prod && npx cap sync android && cd android && ./gradlew assembleRelease",
    "cap:aab": "npm run build:prod && npx cap sync android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@metaplex-foundation/mpl-candy-machine": "^5.1.0",
    "@metaplex-foundation/mpl-core": "^1.4.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.3.0",
    "@metaplex-foundation/umi": "^1.0.0",
    "@metaplex-foundation/umi-bundle-defaults": "^1.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@reown/appkit": "^1.8.19",
    "@sentry/node": "^8.0.0",
    "@sentry/react": "^8.0.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "bs58": "^5.0.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "erc721a": "^4.3.0",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "keccak256": "^1.0.6",
    "lucide-react": "^0.546.0",
    "merkletreejs": "^0.6.0",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "papaparse": "^5.5.3",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "solc": "^0.8.34",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "eventemitter3": "4.0.7",
    "utf-8-validate": "5.0.10"
  },
  "resolutions": {
    "eventemitter3": "4.0.7",
    "utf-8-validate": "5.0.10"
  }
}
